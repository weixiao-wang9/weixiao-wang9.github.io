---
import { research } from '../data/research';

---
<section class="py-16 border-b border-stone-300">
    <h3 class="font-serif text-3xl mb-6 text-charcoal">Research</h3>
    <div>
        {research.map(item => (
            <a href={item.link} class="group flex justify-between items-start gap-6 border-t border-stone-300 py-6">
                <div>
                    <h4 class="font-serif text-xl leading-snug group-hover:text-terracotta transition-colors">{item.title}</h4>
                    <p class="font-sans text-sm text-stone-500 mt-1">{item.summary}</p>
                </div>
                <span class="text-xl shrink-0 group-hover:translate-x-1 transition-transform mt-0.5">→</span>
            </a>
        ))}
        <div class="border-t border-stone-300"></div>
    </div>
</section>